# Environment Variable Configuration Template for Milton Agent Backend
# Copy to .env and populate secret keys locally. Do NOT commit .env to VCS.

# Local Server Settings
MILTON_API_URL=http://127.0.0.1:8000
MILTON_MODE=SUMMARIZE_EVERYTHING
PORT=8000
ENVIRONMENT=development

# Model Router & LLM Keys
# Note: In production, GEMINI_API_KEY is mounted securely via GCP Secret Manager
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_CLOUD_PROJECT=milton-agent-project
GOOGLE_CLOUD_LOCATION=us-central1
